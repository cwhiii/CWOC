<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#fffaf0"
    android:padding="8dp">

    <ImageView
        android:id="@+id/widget_logo"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_centerVertical="true"
        android:layout_alignParentStart="true"
        android:src="@mipmap/ic_launcher"
        android:contentDescription="CWOC" />

    <TextView
        android:id="@+id/widget_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:layout_toEndOf="@id/widget_logo"
        android:layout_marginStart="8dp"
        android:text="New Chit"
        android:textColor="#6b4e31"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/widget_add_icon"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_centerVertical="true"
        android:layout_alignParentEnd="true"
        android:gravity="center"
        android:text="+"
        android:textColor="#fffaf0"
        android:textSize="24sp"
        android:background="#6b4e31" />

</RelativeLayout>
